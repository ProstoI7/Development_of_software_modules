<Window x:Class="Lab3.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Паттерны: Фабрики" Height="450" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Margin="10">
            <TextBlock Text="Выберите цвет: " VerticalAlignment="Center" Margin="0,0,10,0"/>
            <ComboBox x:Name="ColorComboBox" Width="150" SelectionChanged="ComboBox_SelectionChanged">
                <ComboBoxItem Content="Красный"/>
                <ComboBoxItem Content="Синий"/>
                <ComboBoxItem Content="Зелёный"/>
            </ComboBox>
        </StackPanel>

        <StackPanel x:Name="DrawingPanel" Grid.Row="1" Orientation="Horizontal" 
                    HorizontalAlignment="Center" VerticalAlignment="Center"/>
    </Grid>
</Window>